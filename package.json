{
  "name": "devdeck",
  "version": "0.1.0",
  "description": "Project command deck — at-a-glance state + claude -c resume",
  "main": "dist/main/main.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc && node scripts/build-renderer.mjs && node scripts/copy-assets.mjs",
    "dist": "npm run build && electron-builder --win --dir",
    "icons": "tsc && npx electron scripts/gen-icons.js",
    "start": "npm run build && electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "qa": "npm run build && node qa/screenshot.mjs",
    "qa:audit": "npm run build && node qa/audit.mjs"
  },
  "build": {
    "appId": "com.soursea.devdeck",
    "productName": "DevDeck",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    }
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "axe-core": "^4.12.0",
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "playwright": "^1.60.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
