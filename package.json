{
  "name": "devdeck",
  "version": "1.9.0",
  "description": "Project command deck — at-a-glance state + claude -c resume",
  "main": "dist/main/main.js",
  "type": "commonjs",
  "license": "MIT",
  "author": "Si Hyeong Lee",
  "homepage": "https://github.com/writingdeveloper/devdeck#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/writingdeveloper/devdeck.git"
  },
  "keywords": [
    "claude-code",
    "claude",
    "electron",
    "developer-tools",
    "git",
    "dashboard",
    "productivity"
  ],
  "scripts": {
    "build": "tsc && node scripts/build-renderer.mjs && node scripts/copy-assets.mjs",
    "dist": "npm run build && electron-builder --win --dir",
    "dist:installer": "npm run build && electron-builder --win nsis",
    "icons": "tsc && npx electron scripts/gen-icons.js",
    "start": "npm run build && electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "qa": "npm run build && node qa/screenshot.mjs",
    "qa:audit": "npm run build && node qa/audit.mjs"
  },
  "build": {
    "appId": "com.soursea.devdeck",
    "productName": "DevDeck",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/@homebridge/node-pty-prebuilt-multiarch/**"
    ],
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "writingdeveloper",
        "repo": "devdeck"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.png",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "build/icon.png",
      "maintainer": "writingdeveloper <writingdeveloper@users.noreply.github.com>",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "axe-core": "^4.12.0",
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "playwright": "^1.60.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "electron-updater": "^6.8.9"
  }
}
